# ============================================================
# .env.example — Variáveis de Ambiente para Produção (VPS)
# Copie para .env e preencha os valores antes de subir
# ============================================================

# ── JWT ──────────────────────────────────────────────────────
# Chave secreta para assinar tokens. Use uma string longa e aleatória.
JWT_SECRET=TROQUE_POR_UMA_CHAVE_SECRETA_FORTE

# ── PostgreSQL ───────────────────────────────────────────────
# Nome do banco, usuário e senha (usados pelo docker-compose)
POSTGRES_DB=presidente
POSTGRES_USER=wpcrm_user
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE

# URL completa de conexão ao Postgres.
# No Easypanel, o host é o nome do serviço de banco de dados.
# Exemplo: postgresql://wpcrm_user:SENHA@nome_do_projeto_database:5432/presidente
DATABASE_URL=postgresql://wpcrm_user:TROQUE_POR_SENHA_FORTE@database:5432/presidente

# ── WAHA (WhatsApp API) ──────────────────────────────────────
WAHA_API_URL=https://sua-instancia-waha.com/
WAHA_API_KEY=SUA_CHAVE_API_WAHA

# ── Porta da aplicação ───────────────────────────────────────
PORT=9010

# ── Admin padrão (criado no primeiro boot se o banco estiver vazio) ──
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE
